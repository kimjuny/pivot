# =============================================================================
# Pivot — Dev Container (multi-stage)
# Targets:
#   - frontend-dev: Vite development server
#   - backend-dev: FastAPI/Poetry development server
#   - sandbox-base: per-agent sandbox runtime with ripgrep preinstalled
# Pre-installs all dependencies so `podman compose up` is instant
# =============================================================================

# ---- Frontend dev target ----------------------------------------------------
FROM docker.io/library/node:20-alpine AS frontend-dev

WORKDIR /app/web

# Install all dependencies (including devDependencies) into the image
COPY web/package.json web/package-lock.json ./
RUN npm ci --legacy-peer-deps

# Copy config files needed at startup (source is bind-mounted at runtime)
COPY web/vite.config.ts web/tsconfig.json web/tsconfig.node.json ./
COPY web/tailwind.config.js web/postcss.config.js ./
COPY web/eslint.config.js web/components.json ./
COPY web/index.html ./
COPY web/.env.development ./
COPY web/scripts/ ./scripts/
COPY web/src/ ./src/
COPY web/public/ ./public/

EXPOSE 3000


# ---- Sandbox base target ----------------------------------------------------
FROM docker.io/library/python:3.11-slim AS sandbox-base

# Provide the default runtime utilities needed by sandboxed function execution.
# We keep them in the image so every sidecar can start immediately without a
# bootstrap step. Node/npm are installed here because some skills and sandboxed
# tasks need a JavaScript runtime in addition to Python, and Chromium is
# included for browser-driven workflows inside the sandbox.
RUN apt-get update && \
    apt-get install -y --no-install-recommends chromium nodejs npm ripgrep && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace


# ---- Backend dev target -----------------------------------------------------
FROM docker.io/library/python:3.11-slim AS backend-dev

# System deps for compiled Python packages and local type-check tooling.
# Pyright's Python wrapper shells out to Node; bundling nodejs in the dev image
# avoids a nodeenv bootstrap on every fresh container run.
RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libffi-dev nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install Poetry
ENV POETRY_VIRTUALENVS_CREATE=true \
    POETRY_VIRTUALENVS_IN_PROJECT=true \
    POETRY_NO_INTERACTION=1
RUN pip install --no-cache-dir poetry==1.8.5

WORKDIR /app

# Install Python dependencies (including dev deps for linting/type-checking)
COPY pyproject.toml poetry.lock ./
RUN poetry install --no-root && rm -rf /root/.cache

# Copy server code (will be overridden by bind mount in compose)
COPY server/ ./server/

# Create data directory for SQLite persistence
RUN mkdir -p ./server/data

EXPOSE 8003
