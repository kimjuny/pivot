FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY app /app/app

ENV MEM0_SERVICE_HOST=0.0.0.0
ENV MEM0_SERVICE_PORT=8765

CMD ["sh", "-c", "uvicorn app.main:app --host ${MEM0_SERVICE_HOST} --port ${MEM0_SERVICE_PORT}"]
